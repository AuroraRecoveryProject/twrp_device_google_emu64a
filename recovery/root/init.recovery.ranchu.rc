# init.recovery.goldfish.rc
# Recovery-stage init script for Google AVD (goldfish/ranchu virtual hardware)
#

on early-init
    # Load a broader stock-like display stack so we can probe which modules
    # materially affect /dev/dri and minui behavior under ranchu.
    insmod /lib/modules/vexpress-config.ko
    insmod /lib/modules/clk-vexpress-osc.ko
    insmod /lib/modules/pl111_drm.ko
    insmod /lib/modules/virtio_dma_buf.ko
    insmod /lib/modules/virtio_pci_modern_dev.ko
    insmod /lib/modules/virtio_pci.ko
    insmod /lib/modules/failover.ko
    insmod /lib/modules/net_failover.ko
    insmod /lib/modules/virtio_net.ko
    insmod /lib/modules/virtio-gpu.ko
    insmod /lib/modules/vkms.ko

on init
    setprop ro.adb.secure 0

    setprop service.adb.tcp.port 5555
    setprop sys.usb.configfs 0
    setprop ro.hardware goldfish

on fs
    mount ext4 /dev/block/vdc /data noatime,nosuid,nodev,nomblk_io_submit,errors=panic wait,check
    setprop sys.usb.config adb

on property:sys.usb.config=mtp,adb
    setprop sys.usb.config adb

on property:sys.usb.config=adb
    exec u:r:su:s0 root root -- /system/bin/sh -c "ifconfig lo 127.0.0.1 up 2>/dev/null || true; ifconfig eth0 10.0.2.15 netmask 255.255.255.0 up 2>/dev/null || true"

on property:init.svc.recovery=stopped
    exec /system/bin/sh -c "echo '=== TWRP LOG ===' > /dev/kmsg; cat /tmp/recovery.log > /dev/kmsg"

on property:ro.boot.usbcontroller=*
    setprop sys.usb.controller ${ro.boot.usbcontroller}
